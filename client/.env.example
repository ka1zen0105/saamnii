# Production / preview: full URL of the Express API (include protocol, no trailing slash).
# Leave unset in development — the Vite dev server proxies `/api` to the API port.
# VITE_API_URL=https://your-api.example.com

# Optional: API port when it is not in ../server/.env as PORT= (defaults to 3000).
# VITE_API_PORT=5050
